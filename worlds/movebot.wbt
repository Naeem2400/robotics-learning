WorldInfo {
  info [
    "AI Robotics Bootcamp - Project 1: MoveBot"
    "Time-based movement: forward, left turn, forward, stop."
  ]
  title "MoveBot"
  basicTimeStep 32
}
Viewpoint {
  orientation -0.3 -0.13 0.945 4.0
  position 1.4 1.6 1.3
  follow "e-puck"
}
TexturedBackground {
}
TexturedBackgroundLight {
}
RectangleArena {
  floorSize 2 2
  floorAppearance Parquetry {
    textureTransform TextureTransform {
      scale 6 6
    }
  }
  wallHeight 0.08
}
E-puck {
  translation -0.6 -0.6 0
  rotation 0 0 1 0.785
  controller "movebot_controller"
}
